{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "App": ["src/App.js"],
      "assets": ["src/assets"],
      "assets/*": ["src/assets/*"],
      "components/*": ["src/components/*"],
      "config": ["src/config.js"],
      "contexts/*": ["src/contexts/*"],
      "enums/*": ["src/enums/*"],
      "guards/*": ["src/guards/*"],
      "hooks/*": ["src/hooks/*"],
      "i18n/*": ["src/i18n/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "routes/*": ["src/routes/*"],
      "styles/*": ["src/styles/*"],
      "theme/*": ["src/theme/*"],
      "utils/*": ["src/utils/*"]
    }
  },
  "include": ["src"]
}
